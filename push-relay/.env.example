# ─────────────────────────────────────────────────────────────────────────────
# mobilecode-push-relay — environment template.
# NEVER commit a real .env. Copy this file to .env and fill in real values,
# then `chmod 600 .env`. Real secrets belong ONLY in .env (gitignored) and in
# the mounted ./config/*.p8 file (also gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# Runtime.
NODE_ENV=production
PORT=3000

# Admin secret protecting /admin/api-keys. Generate one with:
#   openssl rand -hex 32
ADMIN_SECRET=replace_me_with_64_hex_chars

# SQLite location (inside the container this is a mounted volume).
DB_PATH=/app/data/relay.db

# CORS — set to the origin of the OpenCodeBar watcher / web client if known.
# '*' is fine for a simple api-key-gated relay.
CORS_ORIGIN=*

# Per-api-key push rate limit (requests per minute).
PUSH_RATE_MAX=60

# ── APNs (Apple Push Notifications service) ──────────────────────────────────
# 'false' uses the APNs development gateway; anything else (incl. unset) => production.
APNS_PRODUCTION=true

# Path to the .p8 Auth Key downloaded from the Apple Developer portal
# (Certificates, Identifiers & Profiles → Keys → Auth Keys). Mount it read-only.
# Generate it ONCE — it is not a per-environment cert and is valid until revoked.
APNS_KEY_PATH=/app/config/AuthKey.p8

# The Key ID (10 chars) shown next to the Auth Key in the Developer portal.
APNS_KEY_ID=ABCDE12345

# Your 10-char Apple Team ID (Membership page in the Developer portal).
APNS_TEAM_ID=ABCDE12345

# The app's Bundle ID. This is the APNs "topic" and MUST match the app you built.
APNS_BUNDLE_ID=ai.opencode.remote.ios
